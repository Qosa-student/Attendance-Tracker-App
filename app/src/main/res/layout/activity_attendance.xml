<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC0000"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Classes and Students"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvAttendanceDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Date"
            android:textSize="13sp"
            android:textColor="#FFCCCC"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnTabClasses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Classes"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#CC0000"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTabAttendance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mark Attendance"
            android:textSize="12sp"
            android:textColor="#CC0000"
            android:backgroundTint="#F5F5F5"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTabTypeId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Type ID"
            android:textSize="12sp"
            android:textColor="#CC0000"
            android:backgroundTint="#F5F5F5"/>

    </LinearLayout>

    <!-- TAB 1: MY CLASSES -->
    <LinearLayout
        android:id="@+id/layoutClasses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add a New Class"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#CC0000"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <EditText
                android:id="@+id/etSubjectName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Subject"
                android:padding="10dp"
                android:textSize="13sp"
                android:textColor="#000000"
                android:textColorHint="#AAAAAA"
                android:background="#F5F5F5"
                android:layout_marginEnd="6dp"/>

            <EditText
                android:id="@+id/etSection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Section"
                android:padding="10dp"
                android:textSize="13sp"
                android:textColor="#000000"
                android:textColorHint="#AAAAAA"
                android:background="#F5F5F5"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnAddClass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ADD CLASS"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#CC0000"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Classes"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#CC0000"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/llClassList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </ScrollView>

    </LinearLayout>

    <!-- TAB 2: MARK ATTENDANCE (manual list) -->
    <LinearLayout
        android:id="@+id/layoutManual"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Class"
            android:textSize="13sp"
            android:textColor="#CC0000"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerClass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search by name or ID..."
            android:padding="10dp"
            android:textSize="13sp"
            android:textColor="#000000"
            android:textColorHint="#AAAAAA"
            android:background="#F5F5F5"
            android:layout_marginBottom="10dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/llStudentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </ScrollView>

        <Button
            android:id="@+id/btnSaveAttendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVE ATTENDANCE"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#CC0000"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- TAB 3: TYPE ID -->
    <LinearLayout
        android:id="@+id/layoutTypeId"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search Student by Name or ID"
            android:textSize="13sp"
            android:textColor="#CC0000"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etStudentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter name or ID (e.g. 2024-0001)"
            android:inputType="text"
            android:padding="14dp"
            android:textSize="15sp"
            android:textColor="#000000"
            android:textColorHint="#AAAAAA"
            android:background="#F5F5F5"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select the correct student from results below"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/llSearchResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/llStudentFound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F0FDF4"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected Student:"
                android:textSize="11sp"
                android:textColor="#166534"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvFoundName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#15803D"/>

            <TextView
                android:id="@+id/tvFoundId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#166534"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llNotFound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FEF2F2"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID not found"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#991B1B"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This ID is not registered in the database."
                android:textSize="12sp"
                android:textColor="#B91C1C"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnMarkPresent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Present"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#16A34A"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnMarkAbsent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Absent"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#CC0000"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnMarkLate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Late"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#D97706"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already marked today"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#CC0000"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/llMarkedList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </ScrollView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="8dp">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⌂" android:textSize="20sp" android:textColor="#555555"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="10sp" android:textColor="#555555"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navAttendance" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☑" android:textSize="20sp" android:textColor="#CC0000"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Attendance" android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navScanner" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⊡" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#CC0000" android:padding="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scanner" android:textSize="10sp" android:textColor="#555555"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navReports" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="≡" android:textSize="20sp" android:textColor="#555555"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reports" android:textSize="10sp" android:textColor="#555555"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="◉" android:textSize="20sp" android:textColor="#555555"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="10sp" android:textColor="#555555"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>